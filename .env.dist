APP_NAME="SIMAP Partai"
APP_ENV=local
APP_KEY=base64:UXPgJM84uNIdu1D95Nqqyqqxuz6GDA+cJ6GuWUpw3eI=
APP_DEBUG=true
APP_URL=http://simap-partai.test

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simap_partai
DB_USERNAME=root
DB_PASSWORD=

# Party identity (override config/party.php defaults)
PARTY_SLUG=pdi-p
PARTY_NAME="Partai Demokrasi Indonesia Perjuangan"
PARTY_SHORT_NAME=PDIP
PARTY_APP_NAME="${APP_NAME}"
PARTY_TAGLINE="Sistem Rekap dan Saksi"
PARTY_LOGO=images/logo-pdip.png
PARTY_COLOR_PRIMARY="#DC2626"
PARTY_COLOR_PRIMARY_DARK="#991B1B"
PARTY_HISTORICAL_NUMBERS='{"2024":3}'

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
REKAP_CACHE_TTL_SECONDS=30

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
